# Copy this to .env.prod and fill in values.
# Used by docker-compose.prod.yml.

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=farscry
POSTGRES_PASSWORD=
POSTGRES_DB=farscry

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Public hostname (no protocol) ──────────────────────────────────────────
# The hostname you'll route through Cloudflare Tunnel.
# Example: farscry.example.com
PUBLIC_HOSTNAME=

# ─── Cloudflare Tunnel token ────────────────────────────────────────────────
# From the Cloudflare Zero Trust dashboard after creating a tunnel.
# Format: long base64-encoded string
TUNNEL_TOKEN=
